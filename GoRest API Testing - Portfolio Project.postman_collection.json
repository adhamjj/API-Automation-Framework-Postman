  "item": [
    {
      "name": "00_Authentication",
      "item": [
        {
          "name": "Generate Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();\r",
                  "pm.environment.set(\"booking_token\", jsonData.token);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"username\" : \"admin\",\r\n    \"password\" : \"password123\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "01_Bookings",
      "item": [
        {
          "name": "Create Booking",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const randomSuffix = Math.floor(Math.random() * 10000);\r",
                  "pm.environment.set(\"temp_email\", \"engineer.adham.\" + randomSuffix + \"@test.com\");"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();\r",
                  "pm.environment.set(\"current_booking_id\", jsonData.bookingid);\r",
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "const schema = {\r",
                  "  \"type\": \"object\",\r",
                  "  \"properties\": {\r",
                  "    \"bookingid\": { \"type\": \"number\" },\r",
                  "    \"booking\": {\r",
                  "      \"type\": \"object\",\r",
                  "      \"properties\": {\r",
                  "        \"firstname\": { \"type\": \"string\" },\r",
                  "        \"lastname\": { \"type\": \"string\" },\r",
                  "        \"totalprice\": { \"type\": \"number\" },\r",
                  "        \"depositpaid\": { \"type\": \"boolean\" }\r",
                  "      },\r",
                  "      \"required\": [\"firstname\", \"lastname\", \"totalprice\"]\r",
                  "    }\r",
                  "  },\r",
                  "  \"required\": [\"bookingid\", \"booking\"]\r",
                  "};\r",
                  "\r",
                  "pm.test(\"Schema is valid\", function () {\r",
                  "    pm.response.to.have.jsonSchema(schema);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"firstname\" : \"Adham\",\r\n    \"lastname\" : \"Esam\",\r\n    \"totalprice\" : 111,\r\n    \"depositpaid\" : true,\r\n    \"bookingdates\" : {\r\n        \"checkin\" : \"2026-01-01\",\r\n        \"checkout\" : \"2026-01-02\"\r\n    },\r\n    \"additionalneeds\" : \"Breakfast\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/booking",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "booking"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Update Booking",
          "protocolProfileBehavior": {
            "disableBodyPruning": true
          },
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Cookie",
                "value": "token={{booking_token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"firstname\" : \"Adham\",\r\n    \"lastname\" : \"QA Master\",\r\n    \"totalprice\" : 200,\r\n    \"depositpaid\" : true,\r\n    \"bookingdates\" : {\r\n        \"checkin\" : \"2026-05-01\",\r\n        \"checkout\" : \"2026-05-05\"\r\n    },\r\n    \"additionalneeds\" : \"Sea View\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/booking/{{current_booking_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "booking",
                "{{current_booking_id}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Delete Booking",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Cookie",
                "value": "token={{booking_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/booking/{{current_booking_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "booking",
                "{{current_booking_id}}"
              ]
            }
          },
          "response": []
        }
      ]
    },
